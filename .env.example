# Campus Guardian Drone - Environment Variables Template
# Copy this to .env and fill in your credentials

# =============================================================================
# REQUIRED: Cloudinary Configuration (for image storage)
# Get credentials from: https://cloudinary.com/console
# =============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OR use single URL format:
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# =============================================================================
# OPTIONAL: MongoDB Atlas (if you want external database)
# Get connection string from: https://cloud.mongodb.com
# =============================================================================
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/drone_db

# =============================================================================
# Flask Configuration
# =============================================================================
FLASK_ENV=production              # Use 'development' for local testing
PORT=8080                         # Default port for the application
SECRET_KEY=your-secret-key-here   # Change this for production!

# =============================================================================
# Model Configuration
# =============================================================================
YOLO_MODEL=yolov8n-visdrone.pt    # Lightweight model (recommended)
CONFIDENCE_THRESHOLD=0.25          # Detection confidence threshold

# =============================================================================
# VERCEL/SERVERLESS: HuggingFace Inference API (for cloud deployment)
# Get free API key from: https://huggingface.co/settings/tokens
# Uses HuggingFace's serverless inference - no local PyTorch needed
# =============================================================================
HUGGINGFACE_API_KEY=hf_your_token_here
USE_HF_API=false  # Set to 'true' for Vercel/serverless deployments

# =============================================================================
# OPTIONAL: Telegram Bot (for real-time alerts)
# 1. Create bot: Message @BotFather on Telegram
# 2. Get token from BotFather
# 3. Get chat ID: Message your bot, then visit:
#    https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# =============================================================================
# OPTIONAL: Weather API (for environmental data)
# Get free API key from: https://openweathermap.org/api
# =============================================================================
OPENWEATHER_API_KEY=your_openweather_api_key

# =============================================================================
# Production Deployment Settings (AWS EC2, Render, Railway, etc.)
# =============================================================================
# Set to your domain or public IP
# Example: https://yourdomain.com or http://12.34.56.78:8080
SERVER_URL=http://localhost:8080

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8080,https://yourdomain.com

# =============================================================================
# Raspberry Pi Configuration (for edge devices)
# =============================================================================
# These are used by RPi clients to send data
# SERVER_URL should point to your EC2 instance or domain
# Example: http://ec2-12-34-56-78.compute-1.amazonaws.com:8080
